<view class="player-avatar {{size}} {{isActive ? 'active' : ''}} {{isEmpty ? 'empty' : ''}}" bind:tap="onTap">
  <!-- 空位 -->
  <block wx:if="{{isEmpty}}">
    <view class="avatar-circle empty-circle">
      <text class="empty-icon">+</text>
    </view>
    <text class="name">等待加入</text>
  </block>

  <!-- 玩家 -->
  <block wx:else>
    <view class="avatar-wrapper">
      <image wx:if="{{avatarUrl}}" class="avatar-circle" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-circle default-avatar">
        <text>{{nickname[0] || '?'}}</text>
      </view>

      <!-- 房主标识 -->
      <view wx:if="{{isOwner}}" class="badge owner-badge">👑</view>

      <!-- 喝酒计数 -->
      <view wx:if="{{drinkCount > 0}}" class="badge drink-badge">🍺{{drinkCount}}</view>

      <!-- 护盾标识 -->
      <view wx:if="{{hasShield}}" class="badge shield-badge">🛡️</view>

      <!-- 免疫标识 -->
      <view wx:if="{{isImmune}}" class="immune-glow"></view>
    </view>

    <text class="name">{{nickname || '玩家'}}</text>
  </block>
</view>

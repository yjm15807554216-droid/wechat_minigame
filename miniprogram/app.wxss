/* 全局样式 - 深色酒吧风格 */
page {
  background-color: #16213e;
  color: #e8e8e8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 主色调变量 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  width: 560rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  letter-spacing: 4rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: linear-gradient(135deg, #555, #444);
  color: #999;
}

.btn-secondary {
  width: 560rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: transparent;
  color: #e94560;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: 2rpx solid #e94560;
}

.btn-secondary::after {
  border: none;
}

/* 卡片容器 */
.card-box {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
  backdrop-filter: blur(10px);
}

/* 遮罩层 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

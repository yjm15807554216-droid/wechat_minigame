.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  position: relative;
}

/* 顶部信息栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.info-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
}

.info-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.multiplier-badge {
  background: linear-gradient(135deg, #9B59B6, #8E44AD);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  animation: pulse-badge 1s infinite;
}

.multiplier-badge text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

@keyframes pulse-badge {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* 玩家环 */
.player-ring {
  position: relative;
  width: 100%;
  height: 280rpx;
  margin-bottom: 20rpx;
}

.player-seat {
  position: absolute;
}

/* 2人布局 */
.seat-2-0 { left: 20%; top: 50%; transform: translate(-50%, -50%); }
.seat-2-1 { left: 80%; top: 50%; transform: translate(-50%, -50%); }

/* 3人布局 */
.seat-3-0 { left: 50%; top: 0; transform: translateX(-50%); }
.seat-3-1 { left: 10%; top: 60%; transform: translateX(-50%); }
.seat-3-2 { left: 90%; top: 60%; transform: translateX(-50%); }

/* 4人布局 */
.seat-4-0 { left: 25%; top: 0; transform: translateX(-50%); }
.seat-4-1 { left: 75%; top: 0; transform: translateX(-50%); }
.seat-4-2 { left: 90%; top: 65%; transform: translateX(-50%); }
.seat-4-3 { left: 10%; top: 65%; transform: translateX(-50%); }

/* 5人布局 */
.seat-5-0 { left: 50%; top: 0; transform: translateX(-50%); }
.seat-5-1 { left: 90%; top: 30%; transform: translateX(-50%); }
.seat-5-2 { left: 80%; top: 75%; transform: translateX(-50%); }
.seat-5-3 { left: 20%; top: 75%; transform: translateX(-50%); }
.seat-5-4 { left: 10%; top: 30%; transform: translateX(-50%); }

/* 6人布局 */
.seat-6-0 { left: 25%; top: 0; transform: translateX(-50%); }
.seat-6-1 { left: 75%; top: 0; transform: translateX(-50%); }
.seat-6-2 { left: 95%; top: 50%; transform: translateX(-50%); }
.seat-6-3 { left: 75%; top: 80%; transform: translateX(-50%); }
.seat-6-4 { left: 25%; top: 80%; transform: translateX(-50%); }
.seat-6-5 { left: 5%; top: 50%; transform: translateX(-50%); }

/* 中心游戏区 */
.center-zone {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.draw-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e94560, #c23152);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(233,69,96,0.5);
  animation: glow 2s ease-in-out infinite;
}

.draw-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.draw-text {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 40rpx rgba(233,69,96,0.5); }
  50% { box-shadow: 0 0 60rpx rgba(233,69,96,0.8); }
}

.waiting-text {
  color: rgba(255,255,255,0.5);
  font-size: 28rpx;
}

/* 操作浮层 */
.action-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 150;
  padding-bottom: 60rpx;
}

.action-panel {
  width: 90%;
  background: #1a1a2e;
  border: 2rpx solid rgba(233,69,96,0.3);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  animation: slide-up 0.3s ease-out;
}

@keyframes slide-up {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.action-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.action-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

.target-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 30rpx;
}

.target-item {
  padding: 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255,255,255,0.1);
}

.target-item:active {
  background: rgba(233,69,96,0.2);
  border-color: #e94560;
}

.question-text {
  font-size: 32rpx;
  color: #fff;
  text-align: center;
  line-height: 1.6;
  padding: 20rpx;
}

.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-accept {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-refuse {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 决斗面板 */
.duel-panel {
  align-items: center;
}

.duel-result {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.duel-side {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.duel-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.duel-score {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.vs-text {
  font-size: 40rpx;
  color: #e94560;
  font-weight: bold;
}

.duel-loser {
  font-size: 32rpx;
  color: #e94560;
  font-weight: bold;
}

/* 护盾区域 */
.shield-area {
  position: fixed;
  bottom: 300rpx;
  right: 30rpx;
  z-index: 50;
}

.shield-btn {
  background: rgba(46,204,113,0.2);
  border: 2rpx solid #2ECC71;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.shield-btn text {
  color: #2ECC71;
  font-size: 24rpx;
}

/* 游戏日志 */
.game-log {
  height: 200rpx;
  background: rgba(0,0,0,0.3);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-top: auto;
}

.log-item {
  display: flex;
  gap: 12rpx;
  padding: 6rpx 0;
}

.log-time {
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.log-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.log-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.log-empty text {
  color: rgba(255,255,255,0.3);
  font-size: 24rpx;
}

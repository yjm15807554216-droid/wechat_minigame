<view class="page">
  <!-- 标题 -->
  <view class="header">
    <text class="title">游戏结束!</text>
    <view class="confetti">
      <text class="confetti-item">🎉</text>
      <text class="confetti-item">🎊</text>
      <text class="confetti-item">🥳</text>
    </view>
  </view>

  <!-- MVP展示 -->
  <view class="mvp-section">
    <!-- 酒王 -->
    <view wx:if="{{drinkKing}}" class="mvp-card king">
      <text class="mvp-label">🍺 酒王</text>
      <player-avatar
        nickname="{{drinkKing.nickname}}"
        avatarUrl="{{drinkKing.avatarUrl}}"
        drinkCount="{{drinkKing.totalDrinks}}"
      />
      <text class="mvp-drinks">{{drinkKing.totalDrinks}} 口</text>
    </view>

    <!-- 幸运儿 -->
    <view wx:if="{{luckyOne}}" class="mvp-card lucky">
      <text class="mvp-label">🍀 幸运儿</text>
      <player-avatar
        nickname="{{luckyOne.nickname}}"
        avatarUrl="{{luckyOne.avatarUrl}}"
        drinkCount="{{luckyOne.totalDrinks}}"
      />
      <text class="mvp-drinks">{{luckyOne.totalDrinks}} 口</text>
    </view>
  </view>

  <!-- 排行榜 -->
  <view class="ranking">
    <text class="section-title">排行榜</text>
    <view
      wx:for="{{playerStats}}"
      wx:key="openId"
      class="rank-row"
    >
      <text class="rank-num">{{index + 1}}</text>
      <view class="rank-avatar">
        <player-avatar
          nickname="{{item.nickname}}"
          avatarUrl="{{item.avatarUrl}}"
          size="small"
        />
      </view>
      <view class="rank-bar-wrapper">
        <view class="rank-bar" style="width: {{playerStats[0].totalDrinks > 0 ? (item.totalDrinks / playerStats[0].totalDrinks * 100) : 0}}%"></view>
      </view>
      <text class="rank-drinks">{{item.totalDrinks}}口</text>
    </view>
  </view>

  <!-- 游戏统计 -->
  <view class="stats">
    <view class="stat-item">
      <text class="stat-value">{{totalRounds}}</text>
      <text class="stat-label">总回合</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{duration}}</text>
      <text class="stat-label">游戏时长</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalDrinks}}</text>
      <text class="stat-label">总杯数</text>
    </view>
  </view>

  <!-- 按钮 -->
  <view class="bottom-actions">
    <button class="btn-primary" bind:tap="playAgain">再来一局</button>
    <button class="btn-secondary" bind:tap="goHome">返回首页</button>
    <button class="btn-share" open-type="share">分享战绩</button>
  </view>
</view>

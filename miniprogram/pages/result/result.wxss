.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

/* 标题 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.confetti {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 16rpx;
}

.confetti-item {
  font-size: 40rpx;
  animation: float 2s ease-in-out infinite;
}

.confetti-item:nth-child(2) { animation-delay: 0.3s; }
.confetti-item:nth-child(3) { animation-delay: 0.6s; }

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

/* MVP展示 */
.mvp-section {
  display: flex;
  gap: 30rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.mvp-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.1);
}

.mvp-card.king {
  background: linear-gradient(135deg, rgba(233,69,96,0.15), rgba(194,49,82,0.1));
  border-color: rgba(233,69,96,0.3);
}

.mvp-card.lucky {
  background: linear-gradient(135deg, rgba(46,204,113,0.15), rgba(39,174,96,0.1));
  border-color: rgba(46,204,113,0.3);
}

.mvp-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.mvp-drinks {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 排行榜 */
.ranking {
  width: 100%;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 20rpx;
  display: block;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.rank-num {
  font-size: 28rpx;
  color: rgba(255,255,255,0.4);
  width: 40rpx;
  text-align: center;
  font-weight: bold;
}

.rank-avatar {
  flex-shrink: 0;
}

.rank-bar-wrapper {
  flex: 1;
  height: 24rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 12rpx;
  overflow: hidden;
}

.rank-bar {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #c23152);
  border-radius: 12rpx;
  min-width: 8rpx;
  transition: width 0.8s ease-out;
}

.rank-drinks {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  width: 80rpx;
  text-align: right;
}

/* 统计 */
.stats {
  display: flex;
  width: 100%;
  justify-content: space-around;
  padding: 30rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

/* 底部按钮 */
.bottom-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: auto;
}

.btn-primary {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-secondary {
  background: transparent;
  color: #e94560;
  border: 2rpx solid rgba(233,69,96,0.3);
  border-radius: 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.btn-share {
  background: transparent;
  color: rgba(255,255,255,0.5);
  border: 2rpx solid rgba(255,255,255,0.15);
  border-radius: 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

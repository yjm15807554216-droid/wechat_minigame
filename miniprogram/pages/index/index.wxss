.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx 40rpx;
}

/* Hero区域 */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.card-fan {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
  height: 140rpx;
}

.fan-card {
  font-size: 80rpx;
  transition: transform 0.3s;
}

.fan-1 { transform: rotate(-15deg) translateY(10rpx); }
.fan-2 { transform: rotate(0deg) translateY(-5rpx); margin: 0 -10rpx; }
.fan-3 { transform: rotate(15deg) translateY(10rpx); }

.title {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 16rpx;
  text-shadow: 0 0 30rpx rgba(233,69,96,0.5);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 16rpx;
  letter-spacing: 8rpx;
}

/* 按钮区域 */
.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 80rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  box-shadow: 0 8rpx 30rpx rgba(233,69,96,0.4);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  background: transparent;
  color: #e94560;
  border: 2rpx solid #e94560;
  border-radius: 50rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
}

.btn-secondary:active {
  background: rgba(233,69,96,0.1);
}

/* 玩法提示 */
.tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.tips-title {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

.tips-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 100;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 580rpx;
  background: #1a1a2e;
  border: 2rpx solid rgba(233,69,96,0.3);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  color: #fff;
  text-align: center;
  font-weight: bold;
}

.room-input {
  height: 100rpx;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.15);
  border-radius: 16rpx;
  color: #fff;
  font-size: 48rpx;
  text-align: center;
  letter-spacing: 24rpx;
  padding-left: 24rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-actions .btn-small {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  letter-spacing: 4rpx;
}
